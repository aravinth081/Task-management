# LLM Model Identifier (LiteLLM format, e.g. provider/model-name)
# Supported prefixes include: groq/, openai/, anthropic/, openrouter/
MODEL=groq/llama-3.1-8b-instant

# API key for the selected provider. Uncomment and fill the relevant key:
GROQ_API_KEY=gsk_your_key_here
# OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-...
